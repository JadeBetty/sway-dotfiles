{
    "layer": "bottom",
    "position": "top",
    "height": 30,
    "spacing": 0,
    "modules-left": ["sway/workspaces","sway/mode"],
    "modules-center": ["custom/clock"],
    "modules-right": ["sway/language", "pulseaudio", "battery", "backlight", "tray"],

    "sway/workspaces": {
        "disable-scroll": true,
        "format": "{icon}{name}",
        "format-icons": {
            "default": "",
            "urgent": "!",
            "focused": ""
        }
    },

    "sway/mode": {
        "format": "  {}"
    },

    "custom/clock": {
        "format": "<span color='#45475a'>[ </span>{text}<span color='#45475a'> ]</span>",
        "exec": "date +'%H:%M %A, %b %d' | awk '{print tolower($0)}'",
        "interval": 3
    },

    "sway/language": {
        "format": "<span color='#45475a'>[ </span><span color='#b4befe'><b>key: </b></span>{short}",
        "tooltip": false
    },

    "pulseaudio": {
        "format": "<span color='#45475a'> / </span><span color='#b4befe'><b>{icon}:</b></span> {volume}%",
        "format-muted": "<span color='#45475a'> / </span><span color='#b4befe'><b>{icon}:</b></span> {volume}%",
        "format-icons": {
            "headphone": "iem",
            "hands-free": "iem",
            "headset": "iem",
            "default": ["vol", "iem"] 
        },
        "on-click": "pavucontrol",
        "tooltip-format": "{desc}"
    },

    "battery": {
        "format": "<span color='#45475a'> / </span><span color='#b4befe'><b>bat:</b></span> {capacity}%",
        "format-charging": "<span color='#45475a'> / </span><span color='#b4befe'><b>ac:</b></span> {capacity}%",
        "tooltip": false,
        "interval": 20
    },

    "backlight": {
        "format": "<span color='#45475a'> / </span><span color='#b4befe'><b>mon:</b></span> {percent}%<span color='#45475a'> ]</span>",
        "tooltip": false
    },

    "network": {
        "format-wifi": "<span color='#45475a'> / </span><span color='#b4befe'><b>net:</b></span> up",
        "format-ethernet": "<span color='#45475a'> / </span><span color='#b4befe'><b>net:</b></span> eth",
        "format-disconnected": "<span color='#45475a'> / </span><span color='#b4befe'><b>net:</b></span> down",
        "tooltip-format": "{essid} {signalStrength}%"
    },

    "tray": {
        "icon-size": 20,
        "spacing": 7,
        "tooltip": false
    }
}
